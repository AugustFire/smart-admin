# Auto detect text files and perform LF normalization
* text=auto

# Source code files - force LF
*.js text eol=lf
*.ts text eol=lf
*.vue text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.md text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.java text eol=lf
*.properties text eol=lf
*.sql text eol=lf

# Shell scripts need LF
*.sh text eol=lf

# Windows scripts need CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files - no normalization
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary